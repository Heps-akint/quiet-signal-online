{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "lib": ["DOM", "DOM.Iterable", "ES2024", "WebWorker"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "allowJs": false,
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "@cloudflare/workers-types", "@cloudflare/vitest-pool-workers/types", "node"],
    "baseUrl": ".",
    "paths": {
      "@client/*": ["src/client/*"],
      "@shared/*": ["src/shared/*"],
      "@worker/*": ["src/worker/*"]
    }
  },
  "include": [
    "src",
    "tests",
    "vite.config.ts",
    "playwright.config.ts",
    "vitest.unit.config.ts",
    "vitest.worker.config.ts",
    "eslint.config.js"
  ]
}

{
  "name": "quiet-signal-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:edge": "wrangler dev --port 4173",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:worker",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "hono": "4.12.9",
    "motion": "12.35.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.30.0",
    "@cloudflare/vitest-pool-workers": "0.13.3",
    "@cloudflare/workers-types": "4.20260317.1",
    "@eslint/js": "9.39.3",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.1.1",
    "wrangler": "4.76.0"
  },
  "overrides": {
    "flatted": "3.4.2"
  }
}
